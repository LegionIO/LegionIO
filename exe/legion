#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path('../lib', __dir__))

require 'legion/cli'

# Bare `legion` (no args) drops into interactive chat
# `legion --help` and `legion help` still show full command list
# Piped input with no args goes to headless prompt mode
if ARGV.empty?
  if $stdin.tty?
    ARGV.replace(['chat'])
  else
    ARGV.replace(['chat', 'prompt', ''])
  end
end

Legion::CLI::Main.start(ARGV)
